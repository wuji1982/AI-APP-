# AI共享商城平台 环境变量配置
# 复制此文件为 .env 并修改对应值

# 数据库
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/aixingmu

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=amqp://guest:guest@localhost:5672//
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# JWT密钥(生产环境请更换)
SECRET_KEY=aixingmu-secret-key-change-in-production-2024

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# AI Agent LLM配置
LLM_API_KEY=
LLM_API_BASE=
LLM_MODEL=gpt-4
