# 本地开发环境配置
# 使用SQLite，无需Docker

# ========== 数据库(本地SQLite) ==========
DATABASE_URL=sqlite+aiosqlite:///./aixingmu.db

# ========== Redis(本地Mock) ==========
REDIS_URL=redis://localhost:6379/0

# ========== JWT ==========
SECRET_KEY=aixingmu-dev-secret-key-2024
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ========== 短信(模拟模式) ==========
SMS_PROVIDER=mock

# ========== 调试 ==========
DEBUG=true
